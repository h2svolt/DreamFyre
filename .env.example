# Persistent Turso/libSQL database used by every Vercel function.
TURSO_DATABASE_URL=libsql://your-database-name-your-team.turso.io
TURSO_AUTH_TOKEN=replace_with_your_turso_database_token

# Comma-separated emails that must receive full administrator access.
# Set this before the first admin signs up or signs in.
ADMIN_EMAILS=admin@example.com

# One permanent base64-encoded 32-byte key. Generate it with the command in
# docs/VERCEL_DEPLOYMENT.md and never change it after live game accounts exist.
GAME_CREDENTIAL_ENCRYPTION_KEY=replace_with_a_base64_encoded_32_byte_key

# Production email delivery for verification, password reset and email 2FA.
# AUTH_PREVIEW_OTP must stay false in production.
RESEND_API_KEY=re_replace_with_your_resend_api_key
EMAIL_FROM="DreamFyre <no-reply@your-verified-domain.com>"
AUTH_PREVIEW_OTP=false

# Optional social sign-in. Leave a provider pair blank to keep that provider
# visibly unavailable until the client supplies its official credentials.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
APPLE_CLIENT_ID=
APPLE_CLIENT_SECRET=

# Optional first-line review alerts. These do not replace a professional fraud
# service or the operator's compliance rules.
FRAUD_FAILED_LOGIN_THRESHOLD=5
FRAUD_LARGE_TRANSFER_THRESHOLD=500
FRAUD_LARGE_DEPOSIT_THRESHOLD=1000
FRAUD_LARGE_WITHDRAWAL_THRESHOLD=1000

# Optional client-approved public contact channels.
# These seed the first values only. After first setup the super admin can manage
# Gmail/Facebook/Instagram/WhatsApp destinations from Platform Links.
NEXT_PUBLIC_SUPPORT_EMAIL=
NEXT_PUBLIC_SUPPORT_WHATSAPP_URL=
NEXT_PUBLIC_FACEBOOK_URL=
NEXT_PUBLIC_INSTAGRAM_URL=
